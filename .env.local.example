# OpenAI API 키 (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# 서비스 접속 비밀번호
APP_PASSWORD=change-me-please

# 사용할 OpenAI 모델 (기본: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# --- 공유 DB 설정 (두 분이 같은 데이터 공유하려면 필수) ---
# 값 없으면 자동으로 로컬 파일 ./data/local.db 사용 (본인만 접근)
# Turso (https://turso.tech) 에서 무료 DB 만든 후 아래 2개 값 입력
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
